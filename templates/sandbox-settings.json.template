{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "description": "Sandbox settings template - strengthens security while minimizing the impact on usability. Synced with docs/sandbox-allowlist-recipe.md (29-domain allowlist + 9-domain denylist)",
  "sandbox": {
    "enabled": true,
    "autoAllowBashIfSandboxed": true,
    "excludedCommands": [
      "docker",
      "docker-compose",
      "watchman",
      "systemctl",
      "launchctl",
      "brew services"
    ],
    "network": {
      "allowedDomains": [
        "github.com",
        "api.github.com",
        "raw.githubusercontent.com",
        "codeload.github.com",
        "objects.githubusercontent.com",
        "registry.npmjs.org",
        "api.anthropic.com",
        "pypi.org",
        "files.pythonhosted.org",
        "proxy.golang.org",
        "sum.golang.org",
        "crates.io",
        "static.crates.io",
        "rubygems.org",
        "api.firecrawl.dev",
        "firecrawl.dev",
        "techblog.zozo.com",
        "note.com",
        "assets.st-note.com",
        "zenn.dev",
        "qiita.com",
        "dev.to",
        "medium.com",
        "cdn-ak.f.st-hatena.com",
        "engineering.dena.com",
        "developers.cyberagent.co.jp",
        "tech.uzabase.com",
        "engineer.crowdworks.jp",
        "tech.smarthr.jp"
      ],
      "deniedDomains": [
        "169.254.169.254",
        "metadata.google.internal",
        "metadata.azure.com",
        "pastebin.com",
        "transfer.sh",
        "0x0.st",
        "paste.ee",
        "termbin.com",
        "ix.io"
      ]
    }
  },
  "permissions": {
    "allow": [
      "Bash(git *)",
      "Bash(npm *)",
      "Bash(npx *)",
      "Bash(pnpm *)",
      "Bash(yarn *)",
      "Bash(node *)",
      "Bash(python *)",
      "Bash(pip *)"
    ]
  },
  "_notes": {
    "purpose": "Recommended Sandbox settings based on the Claude Code Permissions documentation",
    "autoAllowBashIfSandboxed": "Setting this to true minimizes permission prompts when the Sandbox is enabled",
    "excludedCommands": "Commands that must run outside the Sandbox (need access to the host system)",
    "allowedDomains": "Three-tier structure: 14 development-core (github / npm / anthropic / pypi / go / crates / rubygems) + 2 Firecrawl core + 13 representative scrape targets (Japanese/English tech blogs). Details: docs/sandbox-allowlist-recipe.md",
    "deniedDomains": "Blocks SSRF (cloud metadata endpoints) + exfiltration routes (pastebin-style sites). deniedDomains takes precedence and is denied even if included in allowedDomains",
    "sync_with": "Keep values and items exactly matched with docs/sandbox-allowlist-recipe.md. Leaving drift unaddressed makes it unclear to the user whether the template or the recipe is authoritative"
  }
}
