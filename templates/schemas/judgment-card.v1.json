{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://harness.local/schemas/judgment-card.v1.json",
  "title": "judgment-card.v1",
  "description": "Decision Card v0 — human judgment prompt during breezing with 2-3 options.",
  "type": "object",
  "required": [
    "question",
    "options",
    "recommendation",
    "confidence",
    "impact",
    "diff_summary"
  ],
  "additionalProperties": false,
  "properties": {
    "question": {
      "type": "string",
      "minLength": 1
    },
    "options": {
      "type": "array",
      "minItems": 2,
      "maxItems": 3,
      "items": {
        "type": "object",
        "required": ["id", "label", "consequence"],
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "label": {
            "type": "string",
            "minLength": 1
          },
          "consequence": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "recommendation": {
      "type": "string",
      "minLength": 1
    },
    "confidence": {
      "type": "string",
      "enum": ["high", "medium", "low"]
    },
    "impact": {
      "type": "string",
      "minLength": 1
    },
    "diff_summary": {
      "type": "string",
      "minLength": 1
    },
    "impact_score": {
      "type": "integer",
      "minimum": 0,
      "maximum": 100
    },
    "similar_past_decisions": {
      "type": "array",
      "maxItems": 3,
      "items": {
        "type": "object",
        "required": ["summary", "decision", "outcome", "decided_at", "mem_id"],
        "additionalProperties": false,
        "properties": {
          "summary": {
            "type": "string"
          },
          "decision": {
            "type": "string"
          },
          "outcome": {
            "type": "string"
          },
          "decided_at": {
            "type": "string"
          },
          "mem_id": {
            "type": "string"
          }
        }
      }
    }
  }
}
