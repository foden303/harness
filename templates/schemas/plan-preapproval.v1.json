{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://harness.local/schemas/plan-preapproval.v1.json",
  "title": "plan-preapproval.v1",
  "description": "Plan-time preapproval record for declared secret reads, external sends, and destructive operations.",
  "type": "object",
  "required": ["schema_version", "approved_at", "approvals"],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "plan-preapproval.v1"
    },
    "approved_at": {
      "type": "string",
      "format": "date-time"
    },
    "approvals": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "item",
          "reason",
          "scope",
          "operations",
          "decision",
          "approved_at"
        ],
        "additionalProperties": false,
        "properties": {
          "item": {
            "type": "string",
            "minLength": 1
          },
          "reason": {
            "type": "string",
            "minLength": 1
          },
          "scope": {
            "type": "object",
            "required": ["phase", "task"],
            "additionalProperties": false,
            "properties": {
              "phase": {
                "type": "string",
                "minLength": 1
              },
              "task": {
                "type": "string",
                "minLength": 1
              }
            }
          },
          "operations": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": {
              "type": "string",
              "enum": ["secret-read", "external-send", "destructive"]
            }
          },
          "paths": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "commands": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "targets": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "decision": {
            "type": "string",
            "enum": ["approved", "denied"]
          },
          "approved_at": {
            "type": "string",
            "format": "date-time"
          },
          "approved_by": {
            "type": "string",
            "minLength": 1
          }
        },
        "anyOf": [
          {"required": ["paths"]},
          {"required": ["commands"]},
          {"required": ["targets"]}
        ]
      }
    }
  }
}
